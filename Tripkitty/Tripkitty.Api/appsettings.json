{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "/app/logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Https": {
        "Url": "https://localhost:7267",
        "Certificate": {
          "Path": "Certs/192.168.1.74+2.pem",
          "KeyPath": "Certs/192.168.1.74+2-key.pem"
        }
      },
      "Http": {
        "Url": "http://localhost:5010"
      }
    }
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Database=tripkitty;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Key": "change-me-in-production-must-be-32-chars-minimum-xxx",
    "Issuer": "tripkitty-api",
    "Audience": "tripkitty-client",
    "AccessTokenExpiryMinutes": "15",
    "RefreshTokenExpiryDays": "30"
  },
